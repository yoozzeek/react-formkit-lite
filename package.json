    "./otherMasks": {
      "types": "./dist/otherMasks.d.ts",
      "import": "./dist/otherMasks.js"
    },
    "./dist/index.css": {
      "import": "./dist/index.css"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:demo": "vite build --mode demo",
    "lint": "eslint --quiet .",
    "lint:fix": "eslint --quiet --fix .",
    "prettier:fix": "prettier --write ."
  },
  "peerDependencies": {
    "@yoozzeek/react-context-modal": ">=0.2.0",
    "react": ">=16.8.0",
    "react-imask": ">=7.6.1",
    "simplebar-react": ">=3.1.0"
  },
