    "./Header": {
      "types": "./dist/Header.d.ts",
      "import": "./dist/Header.js"
    },
    "./Loader": {
      "types": "./dist/Loader.d.ts",
      "import": "./dist/Loader.js"
    },
    "./phoneNumberMask": {
      "types": "./dist/phoneNumberMask.d.ts",
      "import": "./dist/phoneNumberMask.js"
    },
    "./dateMask": {
      "types": "./dist/dateMask.d.ts",
      "import": "./dist/dateMask.js"
